{
  "compilerOptions": {
    "module": "commonjs",
    "target": "es2022",
     "outDir": "./dist",
    "rootDir": "./src",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "types": ["node"],
    "typeRoots": ["./src/types", "./node_modules/@types"],
    "sourceMap": true
  }
}